{
  "name": "simrishamn-tourism-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare-data": "node scripts/prepare-default-data.mjs",
    "prepare-data:deso": "set ORIGIN_GROUPING=deso&& node scripts/prepare-default-data.mjs",
    "prepare-data:city": "set ORIGIN_GROUPING=city&& node scripts/prepare-default-data.mjs",
    "predev": "npm run prepare-data",
    "dev": "vite",
    "prebuild": "npm run prepare-data",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "leaflet": "^1.9.4",
    "recharts": "^2.12.7",
    "lucide-react": "^0.441.0",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2"
  }
}
